import 'package:new_flutter_project/table_view.dart';
import 'package:new_flutter_project/web_view.dart';




void main(){
  runApp( MyApp());
}
class MyApp extends StatelessWidget{
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: "Counter App",
      home:TabbarScreen(),
    );
  }
}
class TabbarScreen extends  StatefulWidget{
  @override
  State<StatefulWidget> createState() => TabbarScreenState();


}
class TabbarScreenState extends State<TabbarScreen>{
  @override
  Widget build(BuildContext context) {
return Scaffold(
  appBar: AppBar(
    title: Text("DeshBord"),
  ),
  body: LayoutBuilder(builder: (context,constraints){
     if (constraints.maxWidth<600){
      return MobileView();
    }else if(constraints.maxWidth<1024){
       return TableView();
     }else{
       return WebView();
     }
  }
  )

);
  }

}
