/////  BottomNavigationBar/////
class HomepageScreen extends StatefulWidget{
  @override
  State<StatefulWidget> createState() => HomepageScreenState();
}
class HomepageScreenState extends State<HomepageScreen>{
  int index=0;
  final List<Widget>Screen=[
    Homescreen(),
    Settingscreen(),
    Notificationscreen(),
    Profilescreen(),
  ];
  @override
  Widget build(BuildContext context) {
return Scaffold(
  appBar: AppBar(
    title: Text("BootomNavigationBar?"),
    titleSpacing: 50,
    toolbarHeight: 100,
    toolbarOpacity: 1,
    elevation: 1,
    backgroundColor: Colors.greenAccent,
  ),
  backgroundColor: Colors.white54,
  body: Screen[index],
  bottomNavigationBar: BottomNavigationBar(
    currentIndex: index,
      unselectedItemColor: Colors.grey,
      selectedItemColor: Colors.black,
      selectedLabelStyle: TextStyle(color: Colors.green),
      unselectedLabelStyle: TextStyle(color: Colors.pink),
      onTap:(i){
      setState(() {
        index=i;
      });
      },
      backgroundColor: Colors.amberAccent,
      items: [
        BottomNavigationBarItem(icon: Icon(Icons.home),label: "Home"),
        BottomNavigationBarItem(icon: Icon(Icons.settings),label: "settings"),
        BottomNavigationBarItem(icon: Icon(Icons.person),label: "Profile"),
        BottomNavigationBarItem(icon: Icon(Icons.notification_add),label: "notification_add"),

      ]
  ),
);
  }

}
